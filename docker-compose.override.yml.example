services:
  backend:
    volumes:
      - ./backend:/app
      - /app/node_modules
    command: npm run dev
    ports:
      - "5000:5000"

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile.dev # We need a dev dockerfile for HMR
    volumes:
      - ./frontend:/app
      - /app/node_modules
    ports:
      - "3000:3000"
    environment:
      - CHOKIDAR_USEPOLLING=true # Helps with file watching in some Docker environments
